# Monochrome Docker settings
MONOCHROME_PORT=3000

# Server-side downloads
MONOCHROME_MUSIC_DIR=../music
DOWNLOAD_DIR=/data/music
TEMP_DIR=/tmp/monochrome-downloads
DOWNLOAD_WORKER_ENABLED=true
DOWNLOAD_WORKER_CONCURRENCY=1
DOWNLOAD_DUPLICATE_CHECK=false
DOWNLOAD_MAINTENANCE_LOCK_TIMEOUT_MS=30000
DOWNLOAD_TRANSIENT_MIN_AGE_MS=900000

# Enable with: COMPOSE_PROFILES=redis and REDIS_URL=redis://monochrome-redis:6379
REDIS_URL=

# Optional provider overrides. Leave blank to use Monochrome's discovered/default instances.
DOWNLOAD_API_INSTANCES=
DOWNLOAD_STREAMING_INSTANCES=
DOWNLOAD_QOBUZ_INSTANCES=
DOWNLOAD_INSTANCE_DISCOVERY=false

# Optional upstream provider settings. Defaults match upstream Monochrome.
AMAZON_MUSIC_ENABLED=true
AMAZON_MUSIC_API_BASE_URL=https://amz.geeked.wtf
AMAZON_MUSIC_CONVERTER_BASE_URL=https://t2a.geeked.wtf
AMAZON_MUSIC_TURNSTILE_SITE_KEY=0x4AAAAAADgxqF6QVMm0GLHH
AMAZON_MUSIC_TURNSTILE_BYPASS_TOKEN=
DEEZER_FALLBACK_ENABLED=true
DEEZER_FALLBACK_API_BASE_URL=https://dzr.tabs-vs-spaces.wtf

# Optional bundled PocketBase profile
POCKETBASE_PORT=8090
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=changeme
